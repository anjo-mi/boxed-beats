      "seed": 378320774,
      "version": 563,
      "versionNonce": 64157722,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1780864033387,
      "link": null,
      "locked": false,
      "text": "Admin vs User vs Guest\nGuest:\n    - View All Songs (Plus Available Contracts)\n        - Search / Filter\n    - Play mp3 version of song\n    - Add Contract to Cart\n        - Proceed to checkout requires Sign In\n    - Sign In\n\nUser:\n    - Check Out\n    - Access Home page\n    - See Purchased Contracts\n    - Click on links to files leased\n        - Download or get URL (?)\n\nAdmin:\n    - Upload Songs + Edit\n    - Upload Contracts + Edit\n    - View all Users + Info\n    - View homepage with transactions",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Admin vs User vs Guest\nGuest:\n    - View All Songs (Plus Available Contracts)\n        - Search / Filter\n    - Play mp3 version of song\n    - Add Contract to Cart\n        - Proceed to checkout requires Sign In\n    - Sign In\n\nUser:\n    - Check Out\n    - Access Home page\n    - See Purchased Contracts\n    - Click on links to files leased\n        - Download or get URL (?)\n\nAdmin:\n    - Upload Songs + Edit\n    - Upload Contracts + Edit\n    - View all Users + Info\n    - View homepage with transactions",
      "autoResize": true,
      "lineHeight": 1.25
    },
