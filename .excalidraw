      "seed": 1361026714,
      "version": 733,
      "versionNonce": 797831002,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1780864442151,
      "link": null,
      "locked": false,
      "text": "Contracts:\n    - Consistency\n        - A user should see a contract with it's most recent\n          price, don't want them to be purchasing a contract\n          only to have the price change mid purchase\n\nTracks:\n    - Availability\n        - An update to a track shouldn't keep a user from\n          being able to finish playing it / see it at all\n\nCart\n    - Consistency\n        - An update to the cart should be reflected on all\n          machines\n\nPurchases\n    - Availability\n        - User and Admin should see *some* purchases\n          new ones will eventually be added",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Contracts:\n    - Consistency\n        - A user should see a contract with it's most recent\n          price, don't want them to be purchasing a contract\n          only to have the price change mid purchase\n\nTracks:\n    - Availability\n        - An update to a track shouldn't keep a user from\n          being able to finish playing it / see it at all\n\nCart\n    - Consistency\n        - An update to the cart should be reflected on all\n          machines\n\nPurchases\n    - Availability\n        - User and Admin should see *some* purchases\n          new ones will eventually be added",
      "autoResize": true,
      "lineHeight": 1.25
    },
