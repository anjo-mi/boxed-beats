    {
      "id": "YEGBakLAUfSnNR3ZZ9KYH",
      "type": "text",
      "x": 93.65482013490237,
      "y": 655.0264094599681,
      "width": 577.4396362304688,
      "height": 500,
      "angle": 0,
      "strokeColor": "#f08c00",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
