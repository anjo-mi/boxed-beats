    {
      "id": "8uUsw-bvfhd8FTDdn-6X4",
      "type": "text",
      "x": 77.2293053082035,
      "y": -15.798978919020158,
      "width": 445.419677734375,
      "height": 525,
      "angle": 0,
      "strokeColor": "#f08c00",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
